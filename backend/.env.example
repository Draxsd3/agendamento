PORT=3001
NODE_ENV=production

# Gere uma chave aleatória forte (ex: openssl rand -base64 64)
JWT_SECRET=sua_chave_secreta_aqui
JWT_EXPIRES_IN=7d

# Encontre no painel do Supabase > Settings > API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# URL do frontend em produção (ex: https://seu-frontend.vercel.app)
CORS_ORIGIN=https://seu-frontend.vercel.app,http://localhost:5173

# Asaas
# sandbox | production
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_KEY=sua_chave_api_asaas

# URLs para redirecionar o cliente depois do checkout
ASAAS_CHECKOUT_SUCCESS_URL=https://seu-frontend.vercel.app/assinatura/sucesso
ASAAS_CHECKOUT_CANCEL_URL=https://seu-frontend.vercel.app/assinatura/cancelada
ASAAS_CHECKOUT_EXPIRED_URL=https://seu-frontend.vercel.app/assinatura/expirada
ASAAS_CHECKOUT_MINUTES_TO_EXPIRE=30

# Token configurado no painel do Asaas em Integracoes > Webhooks
ASAAS_WEBHOOK_TOKEN=gere_um_token_forte_aqui
